# 1. Используем официальный легковесный образ Python
FROM python:3.12-slim
    
# 2. Устанавливаем переменные окружения
# Запрещает Python писать файлы .pyc на диск
ENV PYTHONDONTWRITEBYTECODE=1
# Исключает буферизацию stdout и stderr, логи выводятся сразу
ENV PYTHONUNBUFFERED=1

# 3. Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# 4. Устанавливаем системные зависимости (необходимы для psycopg2, Pillow и т.д.)
RUN apt-get update && apt-get install --no-install-recommends -y \
    build-essential \
    libpq-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 5. Копируем файл зависимостей и устанавливаем их
# Делаем это до копирования кода, чтобы использовать кэширование слоев Docker
COPY requirements.txt /app/
RUN pip install --upgrade pip && pip install --no-cache-dir -r requirements.txt

# 6. Копируем весь проект в рабочую директорию контейнера
COPY . /app/

# 7. Открываем порт, на котором будет работать Django
EXPOSE 8000

# 8. Команда по умолчанию для запуска сервера разработки
CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]
