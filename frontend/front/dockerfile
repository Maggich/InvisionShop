# 1. Используем официальный Node.js
FROM node:20-alpine

# 2. Устанавливаем рабочую директорию
WORKDIR /app

# 3. Копируем файлы конфигурации npm
COPY package*.json ./

# 4. Устанавливаем зависимости
RUN npm install

# 5. Копируем весь исходный код фронтенда
COPY . .

# 6. Открываем порт, который использует Vite по умолчанию
EXPOSE 5173

# 7. Запускаем сервер разработки Vite с флагом --host

CMD ["npm", "run", "dev", "--", "--host", "--force"]
